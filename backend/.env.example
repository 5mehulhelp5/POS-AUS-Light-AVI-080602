# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=pos_user
DB_PASSWORD=your_secure_password
DB_DATABASE=pos_aus_light

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=8h

# Magento Integration
MAGENTO_BASE_URL=https://your-magento-store.com
MAGENTO_ACCESS_TOKEN=your-magento-integration-token
MAGENTO_TIMEOUT=30000

# Sync Settings
SYNC_PRODUCT_INTERVAL=900000
SYNC_INVENTORY_INTERVAL=300000

# Store Settings
STORE_NAME=Australian Lighting & Fans
STORE_ABN=
STORE_ADDRESS=
STORE_PHONE=
TAX_RATE=0.10
